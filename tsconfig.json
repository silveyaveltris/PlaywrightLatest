{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],

    "noEmit": true,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,

    "paths": {
      "@config/*":   ["./config/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@pages/*":    ["./pages/*"],
      "@utils/*":    ["./utils/*"]
    }
  },
  "include": [
    "tests",
    "pages",
    "utils",
    "config",
    "fixtures",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright-report",
    "test-results",
    "allure-results",
    "allure-report"
  ]
}
