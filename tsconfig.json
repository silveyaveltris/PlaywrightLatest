{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "types": ["node", "@playwright/test"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
},
  "include": [
    "tests",
    "pages",
    "utils",
    "config",
    "fixtures",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright-report"
  ]
}