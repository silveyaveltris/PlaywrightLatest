{
  "name": "playwrightonly",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Cross-browser, multi-environment Playwright tests for SauceDemo with storageState auth and Allure reporting.",
  "author": "Silveya Rexee L",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep \"@smoke\"",
    "test:regression": "playwright test --grep \"@regression\"",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "allure:serve": "allure serve allure-results",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "typecheck": "tsc --noEmit",
    "lint":             "eslint .",
    "lint:fix":         "eslint . --fix",
    "format":           "prettier --write .",
    "format:check":     "prettier --check .",
    "clean": "node -e \"['test-results','playwright-report','blob-report','allure-results','allure-report','results-new'].forEach(d => require('fs').rmSync(d, {recursive:true, force:true}))\""
  },

  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.2",
    "prettier": "^3.8.3",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.1"
  }
}
